# =====================================================
# Groq (news agent + institutional agent narratives) — genuinely free,
# no billing/credit card required. Get a key at:
# https://console.groq.com/keys
# =====================================================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# =====================================================
# TradingView webhook
# Must match the "secret" field you put in every Pine Script alert's
# JSON message (see README.md for the exact template).
# =====================================================
TRADINGVIEW_WEBHOOK_SECRET=choose-a-long-random-string

# =====================================================
# Optional: fallback gold/silver history source if Yahoo Finance
# (yfinance) is blocked from your server's IP (common on cloud/VPS —
# see README.md "Known issue" section). Free, no card:
# https://twelvedata.com/pricing
# =====================================================
TWELVE_DATA_API_KEY=

# =====================================================
# Optional: enables POST /api/admin/run/* manual trigger endpoints for
# testing. Leave empty to keep them disabled (404).
# =====================================================
ADMIN_TOKEN=

# =====================================================
# Agent cadence (minutes) — defaults are fine for most users
# =====================================================
NEWS_INTERVAL_MINUTES=15
ZONES_INTERVAL_MINUTES=60
SEASONALITY_INTERVAL_MINUTES=720
INSTITUTIONAL_INTERVAL_MINUTES=180
BACKFILL_INTERVAL_MINUTES=360
COT_INTERVAL_MINUTES=1440
MIN_IMPORTANCE_SCORE=7
MAX_ARTICLES_PER_CYCLE=20
